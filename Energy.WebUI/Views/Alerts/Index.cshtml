@{
    ViewData["Title"] = "Uyarılar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="space-y-3 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-error/10 flex items-center justify-center border border-error/25">
                    <span class="material-symbols-outlined text-error text-3xl">notifications_active</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Uyarılar</h1>
                    <p class="text-sm text-secondary/70 mt-1">Kritik eşik ve anomali bildirimleri burada listelenecek.</p>
                </div>
            </div>
        </header>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 overflow-hidden">
            <div class="px-6 py-4 bg-surface-container-lowest/40 border-b border-outline-variant/10 flex items-center justify-between">
                <span class="text-xs font-headline uppercase tracking-widest text-secondary">Son uyarılar</span>
                <span class="text-[10px] px-2 py-1 rounded bg-surface-container-high text-on-surface-variant">0 kayıt</span>
            </div>
            <div class="p-16 flex flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-6xl text-primary-container/20 mb-4">mark_email_unread</span>
                <p class="text-sm font-headline text-secondary uppercase tracking-widest">Henüz kayıt yok</p>
                <p class="text-xs text-on-surface-variant mt-2 max-w-sm">API ve SignalR entegrasyonu tamamlandığında uyarılar burada görünecek.</p>
            </div>
        </div>
    </div>
</main>
