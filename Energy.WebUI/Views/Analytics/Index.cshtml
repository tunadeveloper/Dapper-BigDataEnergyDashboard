@{
    ViewData["Title"] = "Analitik";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="space-y-3 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-container/10 flex items-center justify-center border border-primary-container/20">
                    <span class="material-symbols-outlined text-primary-container text-3xl">analytics</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Analitik</h1>
                    <p class="text-sm text-secondary/70 mt-1">Tüketim trendleri ve karşılaştırmalı raporlar bu alanda gösterilecek.</p>
                </div>
            </div>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-10 flex flex-col items-center justify-center min-h-[220px]">
                <span class="material-symbols-outlined text-5xl text-primary-container/25 mb-4">insert_chart</span>
                <p class="text-xs font-headline uppercase tracking-[0.2em] text-secondary">Grafik alanı</p>
                <p class="text-sm text-on-surface-variant mt-2 text-center">Veri bağlantısı sonrası doldurulacak</p>
            </div>
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-10 flex flex-col items-center justify-center min-h-[220px]">
                <span class="material-symbols-outlined text-5xl text-primary-container/25 mb-4">compare_arrows</span>
                <p class="text-xs font-headline uppercase tracking-[0.2em] text-secondary">Karşılaştırma</p>
                <p class="text-sm text-on-surface-variant mt-2 text-center">Controller hazır, içerik bekleniyor</p>
            </div>
        </div>
    </div>
</main>
