@{
    ViewData["Title"] = "Raporlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-container/10 flex items-center justify-center border border-primary-container/20">
                    <span class="material-symbols-outlined text-primary-container text-3xl">assessment</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Raporlar</h1>
                    <p class="text-sm text-secondary/70 mt-1">PDF ve Excel çıktıları buradan yönetilecek.</p>
                </div>
            </div>
            <button type="button" disabled class="px-5 py-2.5 rounded-lg text-xs font-headline uppercase tracking-wider bg-surface-container-highest text-on-surface-variant border border-outline-variant/20 cursor-not-allowed opacity-60">Dışa aktar</button>
        </header>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant/10">
            <div class="grid grid-cols-12 gap-px bg-outline-variant/10 text-xs font-headline uppercase tracking-wider text-secondary">
                <div class="col-span-12 sm:col-span-4 bg-surface-container-low px-4 py-3">Rapor adı</div>
                <div class="hidden sm:block col-span-3 bg-surface-container-low px-4 py-3">Dönem</div>
                <div class="hidden sm:block col-span-3 bg-surface-container-low px-4 py-3">Durum</div>
                <div class="hidden sm:block col-span-2 bg-surface-container-low px-4 py-3 text-right">İşlem</div>
            </div>
            <div class="p-12 text-center">
                <span class="material-symbols-outlined text-5xl text-primary-container/25 mb-3 block">description</span>
                <p class="text-sm text-on-surface-variant">Henüz oluşturulmuş rapor yok</p>
            </div>
        </div>
    </div>
</main>
