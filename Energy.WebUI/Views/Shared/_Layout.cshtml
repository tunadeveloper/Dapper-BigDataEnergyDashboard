@inject IConfiguration Configuration
<!DOCTYPE html>

<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} · VoltMetric" : "VoltMetric Enerji Analitik Paneli")</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
        background: rgba(39, 53, 76, 0.6);
        backdrop-filter: blur(20px);
        }
        ::-webkit-scrollbar {
        width: 6px;
        }
        ::-webkit-scrollbar-track {
        background: #041329;
        }
        ::-webkit-scrollbar-thumb {
        background: #1C2A41;
        border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
        background: #00F2FF;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "inverse-surface": "#d6e3ff",
        "secondary-fixed-dim": "#bcc6e6",
        "tertiary-fixed-dim": "#00dbe7",
        "surface-tint": "#00dbe7",
        "surface-container-lowest": "#010e24",
        "primary-container": "#00f2ff",
        "primary": "#e1fdff",
        "error-container": "#93000a",
        "tertiary": "#e1fdff",
        "on-secondary-fixed-variant": "#3c4661",
        "surface-dim": "#041329",
        "on-primary": "#00363a",
        "on-surface": "#d6e3ff",
        "error": "#ffb4ab",
        "on-error": "#690005",
        "tertiary-fixed": "#74f5ff",
        "on-background": "#d6e3ff",
        "on-tertiary": "#00363a",
        "on-secondary": "#263049",
        "inverse-primary": "#00696f",
        "surface-container": "#112036",
        "on-tertiary-container": "#006a71",
        "on-secondary-fixed": "#101b33",
        "on-primary-container": "#006a71",
        "outline-variant": "#3a494b",
        "secondary-container": "#3c4661",
        "tertiary-container": "#00f2ff",
        "inverse-on-surface": "#233148",
        "primary-fixed-dim": "#00dbe7",
        "on-tertiary-fixed": "#002022",
        "outline": "#849495",
        "on-tertiary-fixed-variant": "#004f54",
        "surface-container-highest": "#27354c",
        "surface-bright": "#2c3951",
        "surface": "#041329",
        "on-primary-fixed-variant": "#004f54",
        "background": "#041329",
        "surface-container-low": "#0d1c32",
        "on-secondary-container": "#aab4d4",
        "surface-container-high": "#1c2a41",
        "on-primary-fixed": "#002022",
        "secondary-fixed": "#d9e2ff",
        "primary-fixed": "#74f5ff",
        "on-error-container": "#ffdad6",
        "on-surface-variant": "#b9cacb",
        "surface-variant": "#27354c",
        "secondary": "#bcc6e6"
        },
        "borderRadius": {
        "DEFAULT": "0.125rem",
        "lg": "0.25rem",
        "xl": "0.5rem",
        "full": "0.75rem"
        },
        "fontFamily": {
        "headline": ["Space Grotesk"],
        "body": ["Inter"],
        "label": ["Inter"]
        }
        },
        }
        }
    </script>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
    <header class="fixed top-0 w-full z-50 bg-[#041329] dark:bg-[#041329] shadow-[0_0_40px_rgba(0,242,255,0.05)] border-b border-outline-variant/10">
        <div class="flex justify-between items-center h-16 px-8 w-full max-w-full">
            <div class="flex items-center gap-12">
                <a asp-controller="Dashboard" asp-action="Index" class="text-2xl font-bold tracking-tighter text-[#E1FDFF] font-headline uppercase tracking-[2px]">VoltMetric</a>
            
            </div>
            <div class="flex items-center gap-6">
                <div class="relative group hidden lg:block">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
                    <input class="bg-surface-container-lowest border-none focus:bg-surface-bright focus:ring-0 text-sm py-2 pl-10 pr-4 w-64 rounded-lg transition-all border-b-2 border-transparent focus:border-primary-container" placeholder="Sistemlerde ara..." type="text" />
                </div>
                <div class="flex items-center gap-4">
                    <div id="redis-pulse-status" class="hidden xl:flex items-center gap-2 px-3 py-2 bg-surface-container-highest border border-primary/20 rounded-lg text-[11px] font-headline tracking-wide uppercase text-primary">
                        <span id="redis-pulse-dot" class="w-2 h-2 rounded-full bg-[#00D1FF]"></span>
                        <span id="redis-pulse-text">Redis: - sn | - ms</span>
                    </div>
                    <button class="flex items-center gap-2 px-4 py-2 bg-surface-container-highest border border-primary/20 rounded-lg text-xs font-headline tracking-wider uppercase text-primary hover:bg-surface-bright transition-all active:scale-95">
                        <span class="material-symbols-outlined text-sm">calendar_today</span>
                        Tarih aralığı
                    </button>
                    <div class="flex items-center gap-2">
                        <button class="p-2 text-secondary hover:bg-surface-container-high rounded-full transition-all active:scale-95">
                            <span class="material-symbols-outlined">notifications</span>
                        </button>
                        <button class="p-2 text-secondary hover:bg-surface-container-high rounded-full transition-all active:scale-95">
                            <span class="material-symbols-outlined">settings</span>
                        </button>
                        <div class="w-8 h-8 rounded-full overflow-hidden border border-primary-container/30 ml-2">
                            <img alt="Kullanıcı profili" class="w-full h-full object-cover" data-alt="Modern kontrol odasında yumuşak mavi aydınlatmalı profesyonel enerji mühendisi portresi" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCR5lNMYe63nlmDiFUguqBvaUviSdC0YUMMNpugsjxEoWCD_nFZnNy0npZtA003nAlfZtW_li-b98azPk4WeDw0Cvo86DP8CfU2b2UAALMVCGCc_dcrtzsw9txUaxKGWPkhiKUmtLc1xIySxnJj1G3gm3bGQ4xRazcTwLwabwDJ0KcNqYfjDi6qmRRgETEbYVwSSNS2lZP3kcKNK7Qf2LiPUQdGomK60OJjp3FcdV0GhZO5LeUWGTt601xMRCyh2Y-9jLFG5zTMZA0c" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <aside class="flex flex-col h-screen fixed left-0 top-0 pt-20 bg-[#0D1C32] w-64 border-r border-[#3A494B]/15 z-40 hidden md:flex">
        <div class="px-6 py-4 mb-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-container/20 rounded-lg flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">bolt</span>
                </div>
                <div>
                    <div class="text-sm font-black text-[#00F2FF] font-headline uppercase">Sistem düğümü</div>
                    <div class="text-[10px] text-on-surface-variant/70 tracking-widest font-medium uppercase">Aktif: 104,2 GW</div>
                </div>
            </div>
        </div>
        <nav class="flex-1 px-4 space-y-1">
            <a asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#BCC6E6] hover:bg-[#1C2A41] hover:text-[#E1FDFF] font-['Inter'] text-sm font-medium transition-all cursor-pointer active:opacity-80 hover:backdrop-blur-md">
                <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
                Genel bakış
            </a>
            <a asp-controller="Meter" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#BCC6E6] hover:bg-[#1C2A41] hover:text-[#E1FDFF] font-['Inter'] text-sm font-medium transition-all cursor-pointer active:opacity-80 hover:backdrop-blur-md">
                <span class="material-symbols-outlined">electric_meter</span>
                Sayaçlar
            </a>
            <a asp-controller="MeterReading" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#BCC6E6] hover:bg-[#1C2A41] hover:text-[#E1FDFF] font-['Inter'] text-sm font-medium transition-all cursor-pointer active:opacity-80 hover:backdrop-blur-md">
                <span class="material-symbols-outlined">monitoring</span>
                Okumalar
            </a>
            <a asp-controller="Region" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#BCC6E6] hover:bg-[#1C2A41] hover:text-[#E1FDFF] font-['Inter'] text-sm font-medium transition-all cursor-pointer active:opacity-80 hover:backdrop-blur-md">
                <span class="material-symbols-outlined">public</span>
                Bölgeler
            </a>
        </nav>
    </aside>
   @RenderBody()
    <nav class="fixed bottom-0 left-0 w-full bg-[#0D1C32] md:hidden z-50 px-4 py-3 flex justify-between items-center shadow-[0_-10px_30px_rgba(4,19,41,0.8)]">
        <a asp-controller="Dashboard" asp-action="Index" class="flex flex-col items-center gap-1 text-[#00F2FF]">
            <span class="material-symbols-outlined" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Ana sayfa</span>
        </a>
        <a asp-controller="MeterReading" asp-action="Index" class="flex flex-col items-center gap-1 text-[#BCC6E6]">
            <span class="material-symbols-outlined">monitoring</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Okuma</span>
        </a>
        <div class="relative -top-6">
            <a asp-controller="Meter" asp-action="Index" class="w-12 h-12 bg-gradient-to-tr from-primary to-primary-container rounded-lg shadow-[0_0_20px_rgba(0,242,255,0.4)] flex items-center justify-center text-on-primary">
                <span class="material-symbols-outlined">electric_meter</span>
            </a>
        </div>
        <a asp-controller="Region" asp-action="Index" class="flex flex-col items-center gap-1 text-[#BCC6E6]">
            <span class="material-symbols-outlined">public</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Bölge</span>
        </a>
        <a asp-controller="Meter" asp-action="Index" class="flex flex-col items-center gap-1 text-[#BCC6E6]">
            <span class="material-symbols-outlined">list_alt</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Sayaç</span>
        </a>
    </nav>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            var apiBase = "@(Configuration["EnergyApi:BaseUrl"] ?? "https://localhost:7278/")";
            var hubUrl = String(apiBase).replace(/\/$/, "") + "/hubs/energy";
            var textEl = document.getElementById("redis-pulse-text");
            var dotEl = document.getElementById("redis-pulse-dot");
            if (!textEl || !dotEl || !window.signalR) return;
            var lastPull = null;
            var durationMs = 0;
            function render() {
                if (!lastPull) {
                    textEl.textContent = "Redis: - sn | - ms";
                    return;
                }
                var sec = Math.max(0, Math.floor((Date.now() - lastPull.getTime()) / 1000));
                textEl.textContent = "Redis: " + sec + " sn | " + durationMs + " ms";
            }
            setInterval(render, 1000);
            var connection = new signalR.HubConnectionBuilder().withUrl(hubUrl).withAutomaticReconnect().build();
            connection.on("ReceiveRedisPullStatus", function (payload) {
                var iso = payload && (payload.lastPullAtUtc || payload.LastPullAtUtc);
                durationMs = Number(payload && (payload.pullDurationMs || payload.PullDurationMs || 0)) || 0;
                var isHealthy = Boolean(payload && (payload.isHealthy || payload.IsHealthy));
                lastPull = iso ? new Date(iso) : new Date();
                dotEl.style.backgroundColor = isHealthy ? "#00D1FF" : "#ff6b6b";
                render();
            });
            connection.onclose(function () {
                dotEl.style.backgroundColor = "#ff6b6b";
                textEl.textContent = "Redis: baglanti yok";
            });
            connection.onreconnected(function () {
                dotEl.style.backgroundColor = "#00D1FF";
            });
            function startConnection() {
                connection.start().then(function () {
                    dotEl.style.backgroundColor = "#00D1FF";
                }).catch(function () {
                    dotEl.style.backgroundColor = "#ff6b6b";
                    textEl.textContent = "Redis: baglanti yok";
                    setTimeout(startConnection, 3000);
                });
            }
            startConnection();
        })();
    </script>
</body>
</html>
