@model List<RegionOverviewItemDto>
@using System.Globalization
@{
    ViewData["Title"] = "Bölgeler";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tr = CultureInfo.GetCultureInfo("tr-TR");
}

<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-headline font-bold text-primary tracking-tight">Bölge Yönetimi</h1>
                <p class="text-sm text-secondary">Şebeke bölgeleri, tüketim ve büyüme özeti</p>
            </div>
            <button class="px-4 py-2 rounded-lg bg-primary-container/20 text-primary text-xs font-headline uppercase tracking-wider border border-primary-container/30">Bölge Ekle</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all">
                <div class="text-xs uppercase tracking-[2px] text-secondary mb-2">Toplam bölge</div>
                <div class="text-3xl font-headline font-bold text-primary">@(Convert.ToInt32(ViewBag.TotalRegionCount ?? 0).ToString("N0", tr))</div>
                <div class="text-xs text-primary-fixed-dim mt-2">Sistemde tanımlı bölge adedi</div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all">
                <div class="text-xs uppercase tracking-[2px] text-secondary mb-2">En yüksek tüketim</div>
                <div class="text-3xl font-headline font-bold text-primary">@(ViewBag.TopConsumptionRegionName ?? "-")</div>
                <div class="text-xs text-[#00D1FF] mt-2">@(Convert.ToDecimal(ViewBag.TopConsumptionValue ?? 0m).ToString("N0", tr)) kWh</div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all">
                <div class="text-xs uppercase tracking-[2px] text-secondary mb-2">En çok sayaç</div>
                <div class="text-3xl font-headline font-bold text-primary">@(ViewBag.TopMeterRegionName ?? "-")</div>
                <div class="text-xs text-on-surface-variant mt-2">@(Convert.ToInt32(ViewBag.TopMeterRegionCount ?? 0).ToString("N0", tr)) sayaç</div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all">
                <div class="text-xs uppercase tracking-[2px] text-secondary mb-2">Ortalama voltaj</div>
                <div class="text-3xl font-headline font-bold text-primary">@(Convert.ToDecimal(ViewBag.AverageVoltage ?? 0m).ToString("N0", tr)) V</div>
                <div class="text-xs text-on-surface-variant mt-2">Tüm bölge okumalarının ortalaması</div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6">
            <section class="lg:col-span-6 bg-surface-container-low rounded-xl p-6">
                <h2 class="text-lg font-headline font-bold text-primary mb-6">Bölgesel Performans Kartları</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @foreach (var item in Model ?? new List<RegionOverviewItemDto>())
                    {
                        <article class="p-4 rounded-lg bg-surface-container-high border border-outline-variant/20">
                            <div class="text-sm text-secondary">@item.RegionName</div>
                            <div class="text-xl font-headline text-primary mt-1">@item.TotalConsumption.ToString("N0", tr) kWh</div>
                            <div class="text-xs text-on-surface-variant mt-2">Sayaç: @item.MeterCount | Voltaj: @item.AverageVoltage.ToString("N0", tr) V</div>
                        </article>
                    }
                </div>
            </section>

            <section class="lg:col-span-4 bg-surface-container-low rounded-xl p-6">
                <h2 class="text-lg font-headline font-bold text-primary mb-6">Bölge Payları</h2>
                <div class="space-y-4">
                    @foreach (var item in Model ?? new List<RegionOverviewItemDto>())
                    {
                        <div class="flex items-center justify-between text-xs">
                            <span class="text-secondary">@item.RegionName</span>
                            <span class="text-primary">%@item.SharePercent.ToString("N1", tr)</span>
                        </div>
                        <div class="w-full h-2 rounded bg-surface-container-high"><div class="h-2 rounded bg-primary-container" style="width: @Math.Min(100m, item.SharePercent).ToString("N1", CultureInfo.InvariantCulture)%"></div></div>
                    }
                </div>
            </section>
        </div>
    </div>
</main>
