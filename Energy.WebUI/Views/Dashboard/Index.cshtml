@model List<ResultMeterReadingWithRegionDTO>
@using System.Globalization
@{
    ViewData["Title"] = "Panel";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tr = CultureInfo.GetCultureInfo("tr-TR");
}

<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all group overflow-hidden relative">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-container/5 rounded-full blur-3xl group-hover:bg-primary-container/10 transition-all"></div>
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-headline uppercase tracking-[2px] text-secondary">Toplam tüketim</span>
                    <span class="material-symbols-outlined text-primary-container/40 text-lg">electric_meter</span>
                </div>
                <div class="text-4xl font-headline font-bold text-primary mb-1 drop-shadow-[0_0_15px_rgba(0,242,255,0.4)]">@(ViewBag.TotalConsumption != null ? Convert.ToDecimal(ViewBag.TotalConsumption).ToString("N0", tr) : "—") <span class="text-lg font-light text-primary-fixed-dim">kWh</span></div>
                <div class="flex items-center gap-2 text-xs text-primary-fixed-dim">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    <span>Önceki aya göre +%4,2</span>
                </div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all group overflow-hidden relative">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-container/5 rounded-full blur-3xl group-hover:bg-primary-container/10 transition-all"></div>
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-headline uppercase tracking-[2px] text-secondary">Aktif akıllı sayaç</span>
                    <span class="material-symbols-outlined text-primary-container/40 text-lg">router</span>
                </div>
                <div class="text-4xl font-headline font-bold text-primary mb-1 drop-shadow-[0_0_15px_rgba(0,242,255,0.4)]">@(ViewBag.ActiveMeterCount != null ? Convert.ToInt32(ViewBag.ActiveMeterCount).ToString("N0", tr) : "—")</div>
                <div class="flex items-center gap-2 text-xs text-[#00D1FF]">
                    <span class="w-2 h-2 rounded-full bg-[#00D1FF] animate-pulse"></span>
                    <span>%99,8 sistem çalışma süresi</span>
                </div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-b-2 border-transparent hover:border-primary-container transition-all group overflow-hidden relative">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-container/5 rounded-full blur-3xl group-hover:bg-primary-container/10 transition-all"></div>
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-headline uppercase tracking-[2px] text-secondary">Ortalama şebeke voltajı</span>
                    <span class="material-symbols-outlined text-primary-container/40 text-lg">bolt</span>
                </div>
                <div class="text-4xl font-headline font-bold text-primary mb-1 drop-shadow-[0_0_15px_rgba(0,242,255,0.4)]">@(ViewBag.AverageVoltage != null ? Convert.ToDecimal(ViewBag.AverageVoltage).ToString("N0", tr) : "—")<span class="text-lg font-light text-primary-fixed-dim">V</span></div>
                <div class="flex items-center gap-2 text-xs text-on-surface-variant">
                    <span class="material-symbols-outlined text-sm">check_circle</span>
                    <span>Nominal aralık içinde (±%2)</span>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6">
            <div class="lg:col-span-6 bg-surface-container-low p-8 rounded-xl relative overflow-hidden">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-lg font-headline font-bold text-primary tracking-tight">Aylık enerji yük eğilimi</h3>
                        <p class="text-xs text-secondary/60">Sistem geneli tüketim, gerçek zamanlı (son 12 ay)</p>
                    </div>
                    <div class="flex gap-2">
                        <span class="px-3 py-1 bg-surface-container-high rounded text-[10px] text-primary-container font-bold uppercase tracking-wider">Canlı</span>
                    </div>
                </div>
                <script type="application/json" id="monthly-load-json">@(Html.Raw(ViewBag.MonthlyLoadJson as string ?? "[]"))</script>
                <div class="w-full h-64 mt-4 relative">
                    <svg id="monthly-load-chart" class="w-full h-full" viewBox="0 0 1000 260" preserveAspectRatio="none">
                        <defs>
                            <linearGradient id="monthlyLoadArea" x1="0%" x2="0%" y1="0%" y2="100%">
                                <stop offset="0%" stop-color="#00F2FF" stop-opacity="0.45"></stop>
                                <stop offset="100%" stop-color="#00F2FF" stop-opacity="0.02"></stop>
                            </linearGradient>
                        </defs>
                        <line stroke="#3A494B" stroke-dasharray="4" stroke-width="0.6" x1="0" x2="1000" y1="50" y2="50"></line>
                        <line stroke="#3A494B" stroke-dasharray="4" stroke-width="0.6" x1="0" x2="1000" y1="100" y2="100"></line>
                        <line stroke="#3A494B" stroke-dasharray="4" stroke-width="0.6" x1="0" x2="1000" y1="150" y2="150"></line>
                        <line stroke="#3A494B" stroke-dasharray="4" stroke-width="0.6" x1="0" x2="1000" y1="200" y2="200"></line>
                        <path id="monthly-load-area-path" fill="url(#monthlyLoadArea)" d=""></path>
                        <path id="monthly-load-line-path" fill="none" stroke="#00F2FF" stroke-width="3.2" stroke-linejoin="round" stroke-linecap="round" d=""></path>
                    </svg>
                </div>
                <div id="monthly-chart-labels" class="flex justify-between mt-4 text-[10px] font-headline text-secondary uppercase tracking-widest px-1"></div>
                <script>
                    (function () {
                        var raw = document.getElementById("monthly-load-json");
                        var parsed = JSON.parse(raw && raw.textContent ? raw.textContent : "[]");
                        var points = Array.isArray(parsed) ? parsed : [];
                        var areaPath = document.getElementById("monthly-load-area-path");
                        var linePath = document.getElementById("monthly-load-line-path");
                        var labels = document.getElementById("monthly-chart-labels");
                        if (!areaPath || !linePath || !labels) return;
                        function val(p) { var x = p.consumption != null ? p.consumption : p.Consumption; return Number(x) || 0; }
                        function readingIso(p) { return p.readingDate != null ? p.readingDate : p.ReadingDate; }
                        function monthKey(d) {
                            return d.getUTCFullYear() + "-" + String(d.getUTCMonth() + 1).padStart(2, "0");
                        }
                        var monthTotals = {};
                        points.forEach(function (p) {
                            var d = new Date(readingIso(p));
                            if (!isNaN(d.getTime())) {
                                var k = monthKey(d);
                                monthTotals[k] = (monthTotals[k] || 0) + val(p);
                            }
                        });
                        var now = new Date();
                        var monthly = Array.from({ length: 12 }, function (_, i) {
                            var d = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth() - (11 - i), 1));
                            return { date: d, total: monthTotals[monthKey(d)] || 0 };
                        });
                        var values = monthly.map(function (x) { return x.total; });
                        var max = Math.max.apply(null, values.concat([1]));
                        var min = Math.min.apply(null, values.concat([0]));
                        var span = Math.max(max - min, 1);
                        var W = 1000, H = 260, topPad = 12, bottomPad = 20;
                        var pts = monthly.map(function (p, i) {
                            var x = monthly.length === 1 ? W / 2 : (i / (monthly.length - 1)) * W;
                            var y = topPad + (1 - ((p.total - min) / span)) * (H - topPad - bottomPad);
                            return { x: x, y: y };
                        });
                        var lineD = pts.length ? ("M" + pts[0].x + "," + pts[0].y) : "";
                        for (var i = 1; i < pts.length; i++) lineD += " L" + pts[i].x + "," + pts[i].y;
                        var areaD = lineD ? (lineD + " L" + W + "," + H + " L0," + H + " Z") : "";
                        linePath.setAttribute("d", lineD);
                        areaPath.setAttribute("d", areaD);
                        labels.innerHTML = monthly.map(function (m) {
                            var t = m.date.toLocaleDateString("tr-TR", { month: "short", timeZone: "Europe/Istanbul" });
                            return "<span>" + t + "</span>";
                        }).join("");
                    })();
                </script>
            </div>
            <div class="lg:col-span-4 bg-surface-container-low p-8 rounded-xl flex flex-col items-center">
                <div class="w-full text-left mb-6">
                    <h3 class="text-lg font-headline font-bold text-primary tracking-tight">Bölgesel dağılım</h3>
                    <p class="text-xs text-secondary/60">Coğrafi sektöre göre yük payı</p>
                </div>
                <div class="relative w-48 h-48 flex items-center justify-center my-4">
                    <svg class="w-full h-full -rotate-90" viewbox="0 0 36 36">
                        <circle cx="18" cy="18" fill="none" r="16" stroke="#1C2A41" stroke-width="4"></circle>
                        <circle cx="18" cy="18" fill="none" r="16" stroke="#00F2FF" stroke-dasharray="40, 60" stroke-width="4"></circle>
                        <circle cx="18" cy="18" fill="none" r="16" stroke="#BCC6E6" stroke-dasharray="25, 75" stroke-dashoffset="-40" stroke-width="4"></circle>
                        <circle cx="18" cy="18" fill="none" r="16" stroke="#3A494B" stroke-dasharray="20, 80" stroke-dashoffset="-65" stroke-width="4"></circle>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-headline font-bold text-primary">%40</span>
                        <span class="text-[10px] text-secondary uppercase tracking-widest">Kuzey bölgesi</span>
                    </div>
                </div>
                <div class="w-full mt-6 grid grid-cols-2 gap-4">
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-[#00F2FF]"></div>
                        <span class="text-xs text-on-surface/80">Kuzey: %40</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-[#BCC6E6]"></div>
                        <span class="text-xs text-on-surface/80">Güney: %25</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-[#3A494B]"></div>
                        <span class="text-xs text-on-surface/80">Doğu: %20</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-surface-container-highest"></div>
                        <span class="text-xs text-on-surface/80">Batı: %15</span>
                    </div>
                </div>
            </div>
        </div>
        <section class="bg-surface-container-low rounded-xl overflow-hidden border border-outline-variant/10">
            <div class="p-6 border-b border-outline-variant/10 flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-headline font-bold text-primary uppercase tracking-[1px]">Anomali aktivite günlükleri</h3>
                    <p class="text-xs text-secondary/60">Şebeke dalgalanmaları ve uç tüketimlerin gerçek zamanlı tespiti</p>
                </div>
                <button class="text-xs font-headline text-primary-container border border-primary-container/20 px-4 py-2 rounded hover:bg-primary-container/10 transition-all">Tüm günlükleri gör</button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-surface-container-lowest/50 text-[10px] uppercase tracking-[2px] text-secondary font-headline">
                        <tr>
                            <th class="px-6 py-4">Sayaç ID</th>
                            <th class="px-6 py-4">Durum</th>
                            <th class="px-6 py-4 text-right">Voltaj (V)</th>
                            <th class="px-6 py-4 text-right">Tüketim (kWh)</th>
                            <th class="px-6 py-4">Konum</th>
                            <th class="px-6 py-4 text-right">Zaman damgası</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm font-body divide-y divide-outline-variant/10">
                        @foreach (var item in Model ?? new List<ResultMeterReadingWithRegionDTO>())
                        {
                            <tr class="hover:bg-surface-container-highest/40 transition-colors group">
                                <td class="px-6 py-4 font-headline text-primary tracking-wider">@item.MeterId</td>
                                <td class="px-6 py-4 text-secondary">@item.TariffType</td>
                                <td class="px-6 py-4 text-right font-medium">@item.Voltage</td>
                                <td class="px-6 py-4 text-right">@item.Consumption</td>
                                <td class="px-6 py-4 text-secondary">@item.RegionName</td>
                                <td class="px-6 py-4 text-right text-on-surface-variant font-mono text-xs">@item.ReadingDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</main>
