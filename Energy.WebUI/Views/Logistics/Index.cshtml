@{
    ViewData["Title"] = "Lojistik";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="space-y-3 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-container/10 flex items-center justify-center border border-primary-container/20">
                    <span class="material-symbols-outlined text-primary-container text-3xl">hub</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Lojistik</h1>
                    <p class="text-sm text-secondary/70 mt-1">Saha operasyonları ve ekipman rotaları için yer tutucu sayfa.</p>
                </div>
            </div>
        </header>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 bg-surface-container-low rounded-xl border border-outline-variant/10 p-8 min-h-[280px] flex items-center justify-center">
                <div class="text-center">
                    <span class="material-symbols-outlined text-6xl text-primary-container/20">route</span>
                    <p class="text-sm text-secondary mt-4">Rota özeti</p>
                </div>
            </div>
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-6 space-y-4">
                <p class="text-xs font-headline uppercase tracking-widest text-secondary">Hızlı durum</p>
                <div class="space-y-3">
                    <div class="flex justify-between text-sm"><span class="text-on-surface-variant">Aktif görev</span><span class="text-primary font-headline">—</span></div>
                    <div class="flex justify-between text-sm"><span class="text-on-surface-variant">Bekleyen</span><span class="text-primary font-headline">—</span></div>
                </div>
            </div>
        </div>
    </div>
</main>
