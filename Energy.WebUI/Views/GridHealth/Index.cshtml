@{
    ViewData["Title"] = "Şebeke sağlığı";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="space-y-3 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-container/10 flex items-center justify-center border border-primary-container/20">
                    <span class="material-symbols-outlined text-primary-container text-3xl">grid_4x4</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Şebeke sağlığı</h1>
                    <p class="text-sm text-secondary/70 mt-1">Bölge ve trafo bazlı durum özeti burada yer alacak.</p>
                </div>
            </div>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-6 text-center">
                <p class="text-[10px] font-headline uppercase tracking-widest text-secondary mb-2">Şebeke skoru</p>
                <p class="text-4xl font-headline font-bold text-primary-container">—</p>
            </div>
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-6 text-center">
                <p class="text-[10px] font-headline uppercase tracking-widest text-secondary mb-2">Aktif alarm</p>
                <p class="text-4xl font-headline font-bold text-primary">—</p>
            </div>
            <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-6 text-center">
                <p class="text-[10px] font-headline uppercase tracking-widest text-secondary mb-2">Son tarama</p>
                <p class="text-sm font-mono text-on-surface-variant mt-2">—</p>
            </div>
        </div>
        <div class="bg-surface-container-low rounded-xl border border-dashed border-outline-variant/30 p-12 text-center">
            <span class="material-symbols-outlined text-4xl text-primary-container/30 mb-3 block">map</span>
            <p class="text-xs font-headline uppercase tracking-[0.15em] text-secondary">Harita / topoloji görünümü</p>
            <p class="text-sm text-on-surface-variant mt-2">İçerik yakında eklenecek</p>
        </div>
    </div>
</main>
