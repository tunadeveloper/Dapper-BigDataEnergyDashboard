@{
    ViewData["Title"] = "Yük tahmini";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="md:pl-64 pt-16 min-h-screen bg-surface">
    <div class="p-8 space-y-8 max-w-6xl">
        <header class="space-y-3 border-b border-outline-variant/10 pb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-container/10 flex items-center justify-center border border-primary-container/20">
                    <span class="material-symbols-outlined text-primary-container text-3xl">timeline</span>
                </div>
                <div>
                    <h1 class="text-3xl font-headline font-bold text-primary tracking-tight">Yük tahmini</h1>
                    <p class="text-sm text-secondary/70 mt-1">Saatlik ve günlük yük projeksiyonları bu sayfada olacak.</p>
                </div>
            </div>
        </header>
        <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-8 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-container/5 to-transparent pointer-events-none"></div>
            <div class="relative h-56 rounded-lg bg-surface-container-highest/40 border border-outline-variant/10 flex items-end justify-around px-4 pb-4 gap-1">
                @for (var i = 0; i < 12; i++)
                {
                    var h = 20 + (i * 7) % 55;
                    <div class="w-full max-w-[8%] rounded-t bg-primary-container/30" style="height: @(h)%"></div>
                }
            </div>
            <p class="relative text-center text-xs text-on-surface-variant mt-6">Örnek çubuk yerleşimi — gerçek veri bağlanınca güncellenecek</p>
        </div>
    </div>
</main>
